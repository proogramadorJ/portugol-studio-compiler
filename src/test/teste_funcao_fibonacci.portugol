    funcao inteiro soma(inteiro a, inteiro b){
        retorne a + b
    }

    funcao inteiro mult(inteiro a, inteiro b){
        retorn a * b
    }

    funcao inicio(){
      variavel inteiro a = 10
      variavel inteiro b = 10
      escreva(soma(3, 4))
      escreva(mult(a, b))
    }

      funcao inteiro fibonacci(inteiro n){
            se(n <= 1){
                retorne n
            }
            retorne fibonacci(n - 1) + fibonacci(n - 2)

       }